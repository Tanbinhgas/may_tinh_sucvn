@page
@using may_tinh_sucvn.Models
@model may_tinh_sucvn.Pages.Admin.OrdersModel
@{ ViewData["Title"] = "Quản lý đơn hàng"; }

<div class="cat-pills" style="margin-bottom:18px">
    <a class="btn @(Model.Active is null ? "btn-primary" : "btn-soft") btn-sm" href="/Admin/Orders">Tất cả</a>
    @foreach (var s in Enum.GetValues<OrderStatus>())
    {
        <a class="btn @(Model.Active == s ? "btn-primary" : "btn-soft") btn-sm"
           href="/Admin/Orders?status=@s">@AdminFormat.StatusText(s)</a>
    }
</div>

<div class="panel">
    <table>
        <thead>
            <tr><th>Mã</th><th>Khách hàng</th><th>SĐT</th><th>Ngày đặt</th><th class="right">SL</th><th class="right">Tổng tiền</th><th>Trạng thái</th><th></th></tr>
        </thead>
        <tbody>
            @if (Model.Orders.Count == 0)
            {
                <tr class="empty-row"><td colspan="8">Không có đơn hàng nào.</td></tr>
            }
            else
            {
                @foreach (var o in Model.Orders)
                {
                    <tr>
                        <td>#@o.Id</td>
                        <td>@(o.User?.FullName ?? o.User?.Username ?? "—")</td>
                        <td>@o.Phone</td>
                        <td>@o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="right">@o.Items.Sum(i => i.Quantity)</td>
                        <td class="right">@AdminFormat.Vnd(o.TotalPrice)</td>
                        <td><span class="badge @AdminFormat.StatusBadge(o.Status)">@AdminFormat.StatusText(o.Status)</span></td>
                        <td class="right"><a class="btn btn-soft btn-sm" href="/Admin/OrderDetail/@o.Id">Chi tiết</a></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
