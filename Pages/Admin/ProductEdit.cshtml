@page "/Admin/ProductEdit/{id:int?}"
@using may_tinh_sucvn.Models
@model may_tinh_sucvn.Pages.Admin.ProductEditModel
@{ ViewData["Title"] = Model.IsEdit ? "Sửa sản phẩm" : "Thêm sản phẩm"; }

<div class="toolbar">
    <a class="btn btn-soft" href="/Admin/Products">← Quay lại danh sách</a>
</div>

<div class="panel">
    <div class="panel-body" style="max-width:720px">
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="alert error">@Model.Error</div>
        }

        <form method="post">
            <input type="hidden" asp-for="Input.Id" />

            <div class="field">
                <label asp-for="Input.Name">Tên sản phẩm</label>
                <input asp-for="Input.Name" placeholder="VD: CPU Intel Core i5 12400F" />
            </div>

            <div class="row2">
                <div class="field">
                    <label asp-for="Input.Slug">Slug (để trống sẽ tự tạo)</label>
                    <input asp-for="Input.Slug" placeholder="cpu-intel-core-i5-12400f" />
                </div>
                <div class="field">
                    <label asp-for="Input.CategoryId">Danh mục</label>
                    <select asp-for="Input.CategoryId">
                        @foreach (var c in Model.Categories)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row2">
                <div class="field">
                    <label asp-for="Input.Price">Giá (VNĐ)</label>
                    <input asp-for="Input.Price" type="number" step="1000" min="0" />
                </div>
                <div class="field">
                    <label asp-for="Input.Stock">Tồn kho</label>
                    <input asp-for="Input.Stock" type="number" min="0" />
                </div>
            </div>

            <div class="row2">
                <div class="field">
                    <label asp-for="Input.Brand">Hãng</label>
                    <input asp-for="Input.Brand" placeholder="Intel, ASUS, ..." />
                </div>
                <div class="field">
                    <label asp-for="Input.ImageUrl">Đường dẫn ảnh</label>
                    <input asp-for="Input.ImageUrl" placeholder="/images/product/cpu1.jpg" />
                </div>
            </div>

            <div class="field">
                <label asp-for="Input.Description">Mô tả</label>
                <textarea asp-for="Input.Description" rows="4"></textarea>
            </div>

            <div class="field">
                <label style="display:flex;align-items:center;gap:8px;font-weight:500">
                    <input asp-for="Input.IsActive" type="checkbox" style="width:auto" /> Đang bán (hiển thị trên site)
                </label>
            </div>

            <button class="btn btn-primary" type="submit">@(Model.IsEdit ? "Lưu thay đổi" : "Tạo sản phẩm")</button>
        </form>
    </div>
</div>
