@functions {
    string Grp(string current, params string[] pages) =>
        pages.Any(p => current.StartsWith(p, StringComparison.OrdinalIgnoreCase)) ? "active" : "";
}
@{
    var page = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/images/logo-1.png" />
    <title>@ViewData["Title"] · Quản trị TKL</title>
    <style>
        * { box-sizing:border-box; margin:0; padding:0; }
        body { font-family:'Segoe UI',system-ui,Roboto,sans-serif; background:#f0f2f5; color:#1f2933; }
        a { text-decoration:none; }
        .admin { display:flex; min-height:100vh; }
        /* Sidebar */
        .sidebar { width:230px; background:#16202e; color:#cbd5e1; display:flex; flex-direction:column; position:fixed; top:0; bottom:0; }
        .sidebar .logo { display:flex; align-items:center; gap:10px; padding:18px 20px; font-weight:700; color:#fff; font-size:1.1rem; border-bottom:1px solid #243244; }
        .sidebar .logo img { height:34px; }
        .sidebar nav { display:flex; flex-direction:column; padding:12px 0; }
        .sidebar nav a { padding:12px 22px; color:#9fb0c3; font-size:.95rem; border-left:3px solid transparent; }
        .sidebar nav a:hover { background:#1e2b3c; color:#fff; }
        .sidebar nav a.active { background:#1e2b3c; color:#fff; border-left-color:#e74c3c; }
        /* Content */
        .content { flex:1; margin-left:230px; display:flex; flex-direction:column; }
        .topbar { display:flex; align-items:center; justify-content:space-between; background:#fff; padding:16px 28px; box-shadow:0 1px 3px rgba(0,0,0,.08); position:sticky; top:0; z-index:5; }
        .topbar h1 { font-size:1.3rem; font-weight:600; }
        .topbar .user { display:flex; align-items:center; gap:16px; font-size:.9rem; color:#52606d; }
        .topbar .user .view-site { color:#2563eb; }
        .topbar .user button { background:#16202e; color:#fff; border:none; padding:7px 14px; border-radius:6px; cursor:pointer; font-size:.85rem; }
        .topbar .user button:hover { background:#e74c3c; }
        .body { padding:28px; }
        /* Cards */
        .cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:18px; margin-bottom:28px; }
        .stat { background:#fff; border-radius:12px; padding:20px 22px; box-shadow:0 1px 4px rgba(0,0,0,.06); }
        .stat .label { font-size:.82rem; color:#7b8794; text-transform:uppercase; letter-spacing:.4px; }
        .stat .value { font-size:1.7rem; font-weight:700; margin-top:6px; }
        .stat .value.red { color:#e74c3c; }
        .stat .value.green { color:#16a34a; }
        .stat .value.amber { color:#d97706; }
        /* Panel + table */
        .panel { background:#fff; border-radius:12px; box-shadow:0 1px 4px rgba(0,0,0,.06); margin-bottom:24px; overflow:hidden; }
        .panel > h2 { font-size:1.05rem; padding:16px 20px; border-bottom:1px solid #eef1f4; }
        .panel .panel-body { padding:20px; }
        table { width:100%; border-collapse:collapse; font-size:.9rem; }
        thead th { text-align:left; padding:12px 16px; background:#f8fafc; color:#64748b; font-weight:600; font-size:.78rem; text-transform:uppercase; letter-spacing:.3px; border-bottom:1px solid #eef1f4; }
        tbody td { padding:12px 16px; border-bottom:1px solid #f1f4f7; vertical-align:middle; }
        tbody tr:hover { background:#fafbfc; }
        .thumb-sm { width:42px; height:42px; object-fit:contain; background:#f8fafc; border-radius:6px; }
        /* Badges */
        .badge { display:inline-block; padding:3px 10px; border-radius:20px; font-size:.74rem; font-weight:600; }
        .badge.gray { background:#e5e7eb; color:#374151; }
        .badge.amber { background:#fef3c7; color:#92400e; }
        .badge.blue { background:#dbeafe; color:#1e40af; }
        .badge.purple { background:#ede9fe; color:#5b21b6; }
        .badge.green { background:#dcfce7; color:#166534; }
        .badge.red { background:#fee2e2; color:#991b1b; }
        /* Buttons + forms */
        .btn { display:inline-block; padding:8px 16px; border-radius:7px; border:none; cursor:pointer; font-size:.85rem; font-weight:500; }
        .btn-primary { background:#2563eb; color:#fff; }
        .btn-primary:hover { background:#1d4ed8; }
        .btn-danger { background:#fee2e2; color:#991b1b; }
        .btn-danger:hover { background:#fecaca; }
        .btn-soft { background:#eef2f7; color:#334155; }
        .btn-soft:hover { background:#e2e8f0; }
        .btn-sm { padding:5px 10px; font-size:.78rem; }
        .actions { display:flex; gap:8px; flex-wrap:wrap; }
        .actions form { display:inline; }
        input, select, textarea { font-family:inherit; font-size:.9rem; padding:9px 11px; border:1px solid #cbd5e1; border-radius:7px; width:100%; }
        input:focus, select:focus, textarea:focus { outline:none; border-color:#2563eb; }
        label { display:block; font-size:.82rem; font-weight:600; color:#475569; margin:0 0 6px; }
        .field { margin-bottom:16px; }
        .row2 { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
        .alert { padding:11px 16px; border-radius:8px; margin-bottom:18px; font-size:.9rem; }
        .alert.error { background:#fee2e2; color:#991b1b; }
        .alert.ok { background:#dcfce7; color:#166534; }
        .muted { color:#94a3b8; }
        .right { text-align:right; }
        .toolbar { display:flex; justify-content:space-between; align-items:center; margin-bottom:18px; gap:12px; flex-wrap:wrap; }
        .empty-row td { text-align:center; color:#94a3b8; padding:40px 0; }
        .bar-track { background:#eef1f4; border-radius:6px; height:10px; overflow:hidden; }
        .bar-fill { background:#2563eb; height:100%; }
    </style>
</head>
<body>
    <div class="admin">
        <aside class="sidebar">
            <div class="logo"><img src="/images/logo-1.png" alt="TKL" /> TKL Admin</div>
            <nav>
                <a href="/Admin/Index" class="@Grp(page, "/Admin/Index")">Bảng điều khiển</a>
                <a href="/Admin/Products" class="@Grp(page, "/Admin/Products", "/Admin/ProductEdit")">Sản phẩm</a>
                <a href="/Admin/Orders" class="@Grp(page, "/Admin/Orders", "/Admin/OrderDetail")">Đơn hàng</a>
                <a href="/Admin/Revenue" class="@Grp(page, "/Admin/Revenue")">Doanh thu</a>
                <a href="/Admin/Users" class="@Grp(page, "/Admin/Users")">Người dùng</a>
            </nav>
        </aside>
        <main class="content">
            <header class="topbar">
                <h1>@ViewData["Title"]</h1>
                <div class="user">
                    <a href="/" class="view-site" target="_blank">↗ Xem site</a>
                    <span>@(User.FindFirst("FullName")?.Value ?? "Admin")</span>
                    <form method="post" asp-page="/Logout"><button type="submit">Đăng xuất</button></form>
                </div>
            </header>
            <div class="body">
                @RenderBody()
            </div>
        </main>
    </div>
</body>
</html>
