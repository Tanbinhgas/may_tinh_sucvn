<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lỗi - TKL Computer</title>
</head>
<body>
    <h1>Đã xảy ra lỗi</h1>
