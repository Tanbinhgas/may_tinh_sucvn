@page
@model may_tinh_sucvn.Pages.CartModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/images/logo-1.png" />
    <title>Giỏ hàng - TKL Computer</title>
    <link href="//fonts.googleapis.com/css?family=Montserrat:400,600,700" rel="stylesheet" />
    <link href="/css/store.css" rel="stylesheet" />
</head>
<body>
    <header class="store-header">
        <a class="brand" href="/"><img src="/images/logo-1.png" alt="TKL Computer" /> TKL Computer</a>
        <nav class="store-nav">
            <a href="/">Trang chủ</a>
            <a href="/MyOrders">Đơn của tôi</a>
                <a href="/Profile">Tài khoản</a>
            <form method="post" asp-page="/Logout"><button type="submit">Đăng xuất</button></form>
        </nav>
    </header>

    <div class="wrap">
        <h1 class="page-title">Giỏ hàng của bạn</h1>

        @if (TempData["CartMessage"] is string m)
        {
            <div class="alert error">@m</div>
        }

        @if (Model.Cart.Count == 0)
        {
            <div class="panel"><div class="empty">Giỏ hàng đang trống.<br /><a href="/" class="btn btn-primary" style="margin-top:14px">Tiếp tục mua sắm</a></div></div>
        }
        else
        {
            <div class="panel">
                <table>
                    <thead>
                        <tr><th>Sản phẩm</th><th class="right">Đơn giá</th><th>Số lượng</th><th class="right">Thành tiền</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var line in Model.Cart.Lines)
                        {
                            <tr>
                                <td>
                                    <img class="thumb" src="@(line.ImageUrl ?? "/images/logo-1.png")" alt=""
                                         onerror="this.onerror=null;this.src='/images/logo-1.png';" />
                                    @line.Name
                                </td>
                                <td class="right">@line.Price.ToString("#,##0")₫</td>
                                <td>
                                    <form method="post" asp-page-handler="Update" style="display:flex;gap:6px;align-items:center">
                                        <input type="hidden" name="productId" value="@line.ProductId" />
                                        <input class="qty-input" type="number" name="quantity" value="@line.Quantity" min="0" max="@line.Stock" />
                                        <button type="submit" class="btn btn-soft btn-sm">Cập nhật</button>
                                    </form>
                                </td>
                                <td class="right">@line.LineTotal.ToString("#,##0")₫</td>
                                <td class="right">
                                    <form method="post" asp-page-handler="Remove">
                                        <input type="hidden" name="productId" value="@line.ProductId" />
                                        <button type="submit" class="btn btn-danger btn-sm">Xoá</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="summary-total"><span>Tổng cộng</span><span class="amount">@Model.Cart.Total.ToString("#,##0")₫</span></div>
            </div>

            <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap">
                <form method="post" asp-page-handler="Clear">
                    <button type="submit" class="btn btn-soft">Xoá toàn bộ giỏ</button>
                </form>
                <a href="/Checkout" class="btn btn-primary">Tiến hành đặt hàng →</a>
            </div>
        }
    </div>
</body>
</html>
